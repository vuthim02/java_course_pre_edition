{
  "info": {
    "name": "Social Media Platform",
    "description": "Postman collection for the Social Media Platform project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "postId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "friendshipId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "notificationId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/posts?content=Hello%20world!&imageUrl=https://example.com/image.jpg",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"],
              "query": [
                { "key": "content", "value": "Hello world!" },
                { "key": "imageUrl", "value": "https://example.com/image.jpg" }
              ]
            }
          }
        },
        {
          "name": "Get Post",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}"]
            }
          }
        },
        {
          "name": "Get User Posts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/posts/user/{{userId}}?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "user", "{{userId}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}"]
            }
          }
        },
        {
          "name": "Like Post",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}", "like"]
            }
          }
        },
        {
          "name": "Unlike Post",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/like",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}", "like"]
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/posts/{{postId}}/comments?content=Great%20post!",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "{{postId}}", "comments"],
              "query": [
                { "key": "content", "value": "Great post!" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Friendships",
      "item": [
        {
          "name": "Send Friend Request",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/friendships/request?addresseeId=2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships", "request"],
              "query": [
                { "key": "addresseeId", "value": "2" }
              ]
            }
          }
        },
        {
          "name": "Get Friends",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/friendships",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships"]
            }
          }
        },
        {
          "name": "Get Pending Requests",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/friendships/pending",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships", "pending"]
            }
          }
        },
        {
          "name": "Accept Friend Request",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/friendships/{{friendshipId}}/accept",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships", "{{friendshipId}}", "accept"]
            }
          }
        },
        {
          "name": "Reject Friend Request",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/friendships/{{friendshipId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships", "{{friendshipId}}", "reject"]
            }
          }
        },
        {
          "name": "Remove Friend",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/friendships/{{friendshipId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "friendships", "{{friendshipId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Feed",
      "item": [
        {
          "name": "Get News Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/feed?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "feed"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications"]
            }
          }
        },
        {
          "name": "Get Unread Notifications",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/unread",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "unread"]
            }
          }
        },
        {
          "name": "Get Unread Count",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/unread-count",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "unread-count"]
            }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}", "read"]
            }
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/notifications/read-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "read-all"]
            }
          }
        }
      ]
    }
  ]
}
