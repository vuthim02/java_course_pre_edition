{
  "info": {
    "name": "Trading Platform",
    "description": "Postman collection for the Trading Platform project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"AAPL\",\n  \"orderType\": \"LIMIT\",\n  \"side\": \"BUY\",\n  \"quantity\": 100,\n  \"price\": 150.50,\n  \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "userId", "value": "{{userId}}" }
              ]
            }
          }
        },
        {
          "name": "Get Order By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Portfolio",
      "item": [
        {
          "name": "Get Portfolio",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/portfolio?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "portfolio"],
              "query": [
                { "key": "userId", "value": "{{userId}}" }
              ]
            }
          }
        },
        {
          "name": "Get Portfolio Summary",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/portfolio/{{userId}}/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "portfolio", "{{userId}}", "summary"]
            }
          }
        }
      ]
    },
    {
      "name": "Account",
      "item": [
        {
          "name": "Get Account",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/account?userId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account"],
              "query": [
                { "key": "userId", "value": "{{userId}}" }
              ]
            }
          }
        },
        {
          "name": "Deposit Funds",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 10000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "deposit"]
            }
          }
        },
        {
          "name": "Withdraw Funds",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"amount\": 5000.00\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/account/withdraw",
              "host": ["{{baseUrl}}"],
              "path": ["api", "account", "withdraw"]
            }
          }
        }
      ]
    },
    {
      "name": "Market Data (WebSocket)",
      "item": [
        {
          "name": "Market Data WebSocket",
          "request": {
            "method": "GET",
            "description": "STOMP WebSocket for real-time market data\nEndpoint: /ws/market\n\nSubscribe to:\n- /topic/prices (all prices)\n- /topic/prices/AAPL (specific symbol)\n- /topic/orders/{userId} (user order updates)",
            "url": {
              "raw": "{{baseUrl}}/ws/market",
              "host": ["{{baseUrl}}"],
              "path": ["ws", "market"]
            }
          }
        }
      ]
    }
  ]
}
