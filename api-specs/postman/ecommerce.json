{
  "info": {
    "name": "E-commerce Platform",
    "description": "Postman collection for the E-commerce Platform project",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "itemId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Get Products By Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/category/{{categoryId}}?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "category", "{{categoryId}}"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/search?name=headphones&minPrice=10&maxPrice=200",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "search"],
              "query": [
                { "key": "name", "value": "headphones" },
                { "key": "minPrice", "value": "10" },
                { "key": "maxPrice", "value": "200" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cart/items",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "items"]
            }
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/cart/items/{{itemId}}?quantity=3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "items", "{{itemId}}"],
              "query": [
                { "key": "quantity", "value": "3" }
              ]
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cart/items/{{itemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart", "items", "{{itemId}}"]
            }
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/cart",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cart"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/orders?shippingAddress=123%20Main%20St%2C%20Springfield",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "shippingAddress", "value": "123 Main St, Springfield" }
              ]
            }
          }
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "{{orderId}}"]
            }
          }
        },
        {
          "name": "Get User Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/orders?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"Product description\",\n  \"price\": 29.99,\n  \"stockQuantity\": 100,\n  \"imageUrl\": \"https://example.com/img.jpg\",\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products"]
            }
          }
        },
        {
          "name": "Update Product (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Product\",\n  \"description\": \"Updated description\",\n  \"price\": 39.99,\n  \"stockQuantity\": 50,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/admin/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Delete Product (Admin)",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/admin/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Get All Orders (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/orders?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "orders"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/admin/orders/{{orderId}}/status?status=CONFIRMED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "orders", "{{orderId}}", "status"],
              "query": [
                { "key": "status", "value": "CONFIRMED" }
              ]
            }
          }
        }
      ]
    }
  ]
}
